# SEC RAG configuration surface. Copy to `.env` and fill in.
# `.env` is git-ignored; NEVER commit real secrets. This file declares the keys
# only (no values), and is the single source of truth for what config exists.
# Field mapping and defaults live in configs/settings.py.

# EDGAR requires a User-Agent identifying you, or requests get a 403.
# Format: "Your Name your-email@example.com"
EDGAR_IDENTITY=

# RunPod: embedding compute (backfill GPU pod and serverless endpoint).
RUNPOD_API_KEY=

# Cloudflare R2: raw filing object storage (S3-compatible, no egress fees).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sec-rag-raw
# S3 endpoint for R2: https://<account-id>.r2.cloudflarestorage.com (no bucket, no trailing slash)
R2_ENDPOINT_URL=

# Index/checkpoint database. Defaults to the local docker-compose Postgres; override for prod.
# DATABASE_URL=postgresql+psycopg://sec_rag:sec_rag@localhost:5432/sec_rag

# Qdrant: vector store (local Docker in dev; Cloud free tier for the demo).
QDRANT_URL=http://localhost:6333

# LLM: answer model and evaluation judge (Anthropic or OpenAI).
LLM_API_KEY=
